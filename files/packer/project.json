{
  "builders": [
    {
      "commit": true,
      "image": "{{user `repo_url`}}/ddev:latest",
      "type": "docker"
    }
  ],
  "post-processors": [
    [
      {
        "repository": "{{user `repo_url`}}/{{user `image_name`}}",
        "tags": [
          "0.0.x",
          "{{user `ubuntu_codename`}}-{{isotime `2006-01-02T03-04-05`}}"
        ],
        "type": "docker-tag"
      },
      {
        "type": "docker-push",
        "login": "true",
        "login_server": "{{user `repo_url`}}",
        "login_username": "{{user `login_username`}}",
        "login_password": "{{user `login_password`}}"
      }
    ]
  ],
  "provisioners": [
    {
      "inline": "sudo mkdir -p /var/www/{{user `image_name`}}",
      "type": "shell"
    },
    {
      "destination": "/var/www/{{user `image_name`}}",
      "source": "./.clone/",
      "type": "file"
    },
    {
      "scripts": [
        "scripts/packer/scripts/{{user `image_name`}}.sh"
      ],
      "type": "shell"
    }
  ],
  "variables": {
    "image_name": "{{env `CONTAINER_PROJECT_NAME`}}",
    "repo_url": "{{env `CONTAINER_REGISTRY_URL`}}",
    "ubuntu_version": "{{env `UBUNTU_VERSION`}}",
    "ubuntu_codename": "{{ env `UBUNTU_CODENAME`}}",
    "ddev_version": "{{env `DDEV_VERSION`}}",
    "login_username": "{{env `CONTAINER_REGISTRY_USERNAME`}}",
    "login_password": "{{env `CONTAINER_REGISTRY_PASSWORD`}}"
  }
}

